{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "The Prometheus scraping your Brewmetheus exporter.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Blood caffeine (mg/L)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "drawStyle": "line", "fillOpacity": 12, "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "blood caffeine" },
            "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "#3fb950" } }]
          }
        ]
      },
      "targets": [
        { "expr": "brewmetheus_blood_caffeine_mg_per_litre", "legendFormat": "blood caffeine", "refId": "A" },
        { "expr": "brewmetheus_awake_threshold_mg_per_litre", "legendFormat": "awake threshold", "refId": "B" },
        { "expr": "brewmetheus_insomnia_threshold_mg_per_litre", "legendFormat": "insomnia threshold", "refId": "C" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Clarity SLA (today)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#f85149", "value": null },
              { "color": "#d29922", "value": 0.8 },
              { "color": "#3fb950", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "expr": "brewmetheus_clarity_sla_ratio", "refId": "A" }]
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "Daily cap used",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#3fb950", "value": null },
              { "color": "#d29922", "value": 0.75 },
              { "color": "#f85149", "value": 1.0 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "brewmetheus_caffeine_daily_total_mg / brewmetheus_caffeine_daily_cap_mg",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Error budget burn rate",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#3fb950", "value": null },
              { "color": "#d29922", "value": 1 },
              { "color": "#f85149", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [{ "expr": "brewmetheus_error_budget_burn_rate", "refId": "A" }]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Caffeine intake rate (mg/h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 16, "x": 8, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "none", "custom": { "drawStyle": "bars", "fillOpacity": 40 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "rate(brewmetheus_caffeine_intake_mg_total[1h]) * 3600",
          "legendFormat": "mg/h",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["brewmetheus", "caffeine"],
  "templating": { "list": [] },
  "time": { "from": "now-12h", "to": "now" },
  "timezone": "browser",
  "title": "Brewmetheus — Caffeine Service",
  "uid": "brewmetheus",
  "version": 1
}
